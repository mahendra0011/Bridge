{
  "name": "bridge-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "seed": "node src/scripts/seed.js",
    "seed:full": "node seed-company.js && node seed-demo-users.js && node src/scripts/seed.js",
    "seed:company": "node seed-company.js",
    "seed:demo-users": "node seed-demo-users.js",
    "check-alerts": "node src/scripts/checkSavedSearchAlerts.js",
    "security-audit": "npm audit --audit-level=high",
    "lint": "node --check src/**/*.js"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.19.1",
    "sanitize-html": "^2.17.5",
    "socket.io": "^4.7.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}

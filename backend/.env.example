PORT=5000
MONGO_URI=
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Email (Brevo transactional email API — NOT SMTP)
# Get this from Brevo dashboard > SMTP & API > API Keys
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM=Bridge <no-reply@bridge.io>

# Frontend URL (for email links)
CLIENT_URL=http://localhost:5173

# Admin seed script (npm run seed:admin) — creates/updates the first admin user
ADMIN_EMAIL=admin@bridge.io
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_NAME=Admin

# ─── Google OAuth ─────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com > APIs & Services > Credentials
# Create an OAuth 2.0 Client ID (Web application type)
# Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Cloudinary (optional — for production file storage) ──────────────────
# Leave blank to use local disk storage (fine for local dev).
# In production (Render, Railway, etc.) set all three to avoid file loss.
# Get from: https://cloudinary.com > Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=














































# Leave empty to use Vite's dev proxy (see vite.config.js) which forwards
# /api and /uploads to http://localhost:5000.
# In production, set this to your deployed backend's URL, e.g. https://api.bridge.io
VITE_API_URL=

# Google OAuth Client ID (from Google Cloud Console)
# This is needed to enable the "Continue with Google" button on the login page.
# If not set, the button will be disabled.
VITE_GOOGLE_CLIENT_ID=












































